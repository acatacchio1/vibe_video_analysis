# Video Analyzer Web - Environment Configuration
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git - it contains secrets!

# OpenRouter API Key (required for OpenRouter provider)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenWebUI API Key (required for Knowledge Base sync)
# Get your key from: OpenWebUI → Settings → Account → API Keys
OPENWEBUI_API_KEY=your_openwebui_api_key_here

# OpenWebUI API Key (required for Knowledge Base sync)
# Get your key from: OpenWebUI → Settings → Account → API Keys
OPENWEBUI_API_KEY=your_openwebui_api_key_here
